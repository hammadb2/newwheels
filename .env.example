# =============================================================
# NewWheels env vars
# Copy to .env.local for local dev. Set the same keys in Vercel.
# All keys are optional. The site renders fine without them,
# but tracking + form integrations only activate when they are set.
# =============================================================

# Public site URL (used for canonicals, OG, sitemap, schema)
NEXT_PUBLIC_SITE_URL=https://newwheels.ca

# --- Business info (overrides defaults in src/lib/site.ts) ---
NEXT_PUBLIC_BUSINESS_PHONE=
NEXT_PUBLIC_BUSINESS_PHONE_HREF=
NEXT_PUBLIC_BUSINESS_ADDRESS_STREET=
NEXT_PUBLIC_BUSINESS_ADDRESS_LOCALITY=Calgary
NEXT_PUBLIC_BUSINESS_ADDRESS_REGION=AB
NEXT_PUBLIC_BUSINESS_ADDRESS_POSTAL=
NEXT_PUBLIC_AMVIC_LICENSE=
NEXT_PUBLIC_HAMMAD_LAST_NAME=

# --- Tracking IDs (load via GTM as primary, direct as fallback) ---
NEXT_PUBLIC_GTM_ID=
NEXT_PUBLIC_GA4_ID=
NEXT_PUBLIC_FB_PIXEL_ID=
NEXT_PUBLIC_CLARITY_ID=
NEXT_PUBLIC_GSC_VERIFICATION=

# --- Server-only: lead submission integrations ---
# Resend.com API key for outbound email (lead notification + auto-reply)
RESEND_API_KEY=
# Where to send the lead notification email
LEAD_NOTIFY_TO=
# From address for lead notifications + auto-reply
LEAD_FROM_EMAIL=hello@newwheels.ca
# Google Apps Script webhook URL. Appends to the lead-tracking Sheet
GOOGLE_SHEETS_WEBHOOK_URL=

# --- /admin/* gate (Phase 2 internal panel) ---
# Long random string. Auth gate for everything under /admin/*.
# Set, then visit /admin/login?token=<value> once to authenticate.
ADMIN_TOKEN=

# --- Content pipeline (admin/content) ---
# Claude API key. Required only to generate new resource drafts.
ANTHROPIC_API_KEY=
# Optional override of the Claude model.
ANTHROPIC_MODEL=

# --- SEO dashboard + GBP sync (admin/seo, admin/gbp) ---
# Service account JSON, pasted inline as a single env value.
# The service account must be a verified owner of the GSC property, have
# Viewer access on the GA4 property, and be a manager on the GBP listing.
GOOGLE_SERVICE_ACCOUNT_JSON=
# GSC site URL (the same property string GSC uses, e.g. "https://newwheels.ca/")
GSC_PROPERTY_URL=https://newwheels.ca/
# GA4 numeric property ID.
GA4_PROPERTY_ID=
# Google Business Profile account + location IDs (with or without "accounts/"
# and "locations/" prefixes; either form is accepted).
GBP_ACCOUNT_ID=
GBP_LOCATION_ID=
